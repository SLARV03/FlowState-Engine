# ─── LLM Configuration ───────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-your-api-key-here
LLM_TEMPERATURE_PM=0.4
LLM_TEMPERATURE_SWE=0.2
LLM_TEMPERATURE_QA=0.1

# ─── Sandbox Configuration ───────────────────────────────────
SANDBOX_BASE_IMAGE_PYTHON=python:3.11-alpine
SANDBOX_BASE_IMAGE_NODE=node:20-alpine
SANDBOX_BASE_IMAGE_GO=golang:1.22-alpine
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_LIMIT=0.5

# ─── Server Configuration ────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
MAX_ITERATIONS=5

# ─── Frontend Configuration ──────────────────────────────────
VITE_WS_URL=ws://localhost:8000/ws
VITE_API_URL=http://localhost:8000/api
